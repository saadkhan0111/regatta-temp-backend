# ─── RegattaStream Backend — Environment Config ───────────────────────────────
# Copy to .env and fill in values. Never commit .env to git.

# ── SERVER ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development            # development | production

# ── MONGODB ─────────────────────────────────────────────────────────────────
# Local dev:
MONGODB_URI=mongodb://localhost:27017/regattastream
# Atlas (production):
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/regattastream?retryWrites=true&w=majority

# ── AUTH ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-64-char-random-string
JWT_EXPIRES_IN=7d

# ── ANTHROPIC (AI race stories, campaign copy) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── EMAIL (Nodemailer — campaigns, transactional) ───────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.your-sendgrid-api-key
EMAIL_FROM=noreply@regattastream.com
EMAIL_FROM_NAME=RegattaStream

# ── STRIPE (subscriptions, club Pro, donations) ──────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_CLUB_PRICE_ID=price_...

# ── TIMING PARTNER APIs ──────────────────────────────────────────────────────
HERENOW_API_KEY=...
HERENOW_BASE_URL=https://api.herenow.com/v1
REGATTACENTRAL_API_KEY=...
REGATTACENTRAL_BASE_URL=https://api.regattacentral.com/v2
CREWTIMER_API_KEY=...
REGATTAMASTER_API_KEY=...

# ── FILE UPLOADS ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25

# ── APP URLS ─────────────────────────────────────────────────────────────────
FRONTEND_URL=https://regattastream.com
APP_IOS_URL=https://apps.apple.com/us/app/regattastream/...
APP_ANDROID_URL=https://play.google.com/store/apps/details?id=com.regattastream

# ── CRON SYNC INTERVALS (minutes) ────────────────────────────────────────────
SYNC_HERENOW_INTERVAL=2
SYNC_REGATTACENTRAL_INTERVAL=5
SYNC_CREWTIMER_INTERVAL=10
SYNC_REGATTAMASTER_INTERVAL=60
