{
    "version": 2,
    "builds": [
        {
            "src": "./src/server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/docs",
            "dest": "/src/server.js"
        },
        {
            "src": "/(.*)",
            "dest": "/src/server.js"
        }
    ]
}